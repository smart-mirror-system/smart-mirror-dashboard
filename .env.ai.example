# =========================
# Smart Mirror AI Service
# =========================

# Backend Socket.IO URL
# Example (local dev):
# http://localhost:3000
BACKEND_URL=http://smart-mirror-api:3000


# =====================================
# Authentication (Development Only)
# =====================================
# Use a real JWT returned from:
# POST /api/auth/login
AI_JWT=PUT_USER_LOGIN_TOKEN_HERE


# =========================
# Exercise Configuration
# =========================
# pushup | squat | bicep_curl | situp | ...
EXERCISE_TYPE=pushup


# =========================
# Camera Configuration
# =========================
# Usually 0 (default webcam)
CAMERA_INDEX=0


# =========================
# Model Configuration
# =========================
# lightweight | balanced | performance
MODEL_MODE=lightweight


# =========================
# Streaming Configuration
# =========================
# Minimum interval between socket updates (milliseconds)
SEND_EVERY_MS=250


# =========================
# Debug Options
# =========================

# 1 = show debug camera window
# 0 = fully headless (production)
SHOW_CAMERA=0

# 1 = export live JSON file (legacy debug mode)
# 0 = disable JSON export (recommended for production)
EXPORT_JSON=0